---
import { siteConfig } from '../config/site.config';

const items = [
  'Lun–Vie: 9:00 – 19:00h',
  siteConfig.phoneDisplay,
  siteConfig.email,
  'Comunidad de Madrid',
  `${siteConfig.address.city} · ${siteConfig.address.region}`,
  'Interiorismo · Decoración · Reformas',
];
---

<div class="ticker" aria-hidden="true">
  <div class="ticker-inner">
    {items.map((item) => <span>{item}</span>)}
    {items.map((item) => <span>{item}</span>)}
  </div>
</div>

<style>
  .ticker {
    background: var(--ink);
    color: var(--bg);
    font-family: var(--body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .04em;
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }
  .ticker-inner {
    display: inline-flex;
    gap: 48px;
    animation: ticker 28s linear infinite;
  }
  .ticker-inner span::before {
    content: '//';
    margin-right: 12px;
    opacity: .45;
  }
  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
