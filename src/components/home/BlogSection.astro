---
import ArrowIcon from '../ArrowIcon.astro';

const posts = [
  {
    date: '12 noviembre 2025',
    title: 'Interiorismo centrado en las personas',
    excerpt: 'Cómo los arquitectos trasladan la visión al espacio, mezclando contexto, materialidad y tecnología para elevar la vida cotidiana.',
    href: '/blog/interiorismo-centrado-personas',
    image: 'https://images.unsplash.com/photo-1534595038511-9f219fe0c979?w=700&q=70&auto=format&fit=crop',
    alt: 'Interiorismo que centra al ser humano',
  },
  {
    date: '22 octubre 2025',
    title: 'Tendencias de decoración 2025 que perduran',
    excerpt: 'Estrategias para transformar espacios existentes en entornos de alto rendimiento sin perder su carácter original.',
    href: '/blog/tendencias-decoracion-2025',
    image: 'https://images.unsplash.com/photo-1631679706909-1844bbd07221?w=700&q=70&auto=format&fit=crop',
    alt: 'Tendencias decoración 2025',
  },
  {
    date: '14 septiembre 2025',
    title: 'Diseño que promueve el bienestar',
    excerpt: 'Decisiones de diseño con base científica que ayudan a que los espacios de trabajo y hogar nutran la calma, la conexión y la recuperación.',
    href: '/blog/diseno-bienestar',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=700&q=70&auto=format&fit=crop',
    alt: 'Bienestar a través del diseño interior',
  },
];
---

<section class="section" style="background: var(--bg);">
  <div class="container">
    <div class="journal-header">
      <div>
        <div class="section-label">Inspiración y tendencias</div>
        <h2 class="editorial-headline">El <em>blog</em> de ByHilde</h2>
      </div>
      <a href="/blog" class="see-all">
        Ver todos los artículos
        <ArrowIcon size={14} />
      </a>
    </div>
    <div class="journal-grid">
      {posts.map((post) => (
        <a href={post.href} class="journal-card">
          <div class="journal-card-img">
            <img src={post.image} alt={post.alt} width="700" height="467" loading="lazy">
          </div>
          <div class="journal-card-body">
            <div class="journal-date">{post.date}</div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <span class="journal-read">
              Leer artículo
              <ArrowIcon size={14} />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .journal-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
  }
  .journal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .journal-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform .3s, box-shadow .3s;
    cursor: pointer;
    display: block;
  }
  .journal-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(26,25,22,.10);
  }
  .journal-card-img {
    height: 200px;
    overflow: hidden;
  }
  .journal-card-img img {
    height: 100%;
    transition: transform .5s;
  }
  .journal-card:hover .journal-card-img img { transform: scale(1.06); }
  .journal-card-body { padding: 22px 24px 26px; }
  .journal-date {
    font-size: 11.5px;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .journal-card h3 {
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .journal-card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .journal-read {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap .2s;
  }
  .journal-card:hover .journal-read { gap: 10px; }

  @media (max-width: 1024px) {
    .journal-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .journal-grid { grid-template-columns: 1fr; }
  }
</style>
