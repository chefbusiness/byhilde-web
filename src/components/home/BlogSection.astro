---
import ArrowIcon from '../ArrowIcon.astro';

import img1 from '../../assets/images/blog/interiorismo-centrado-personas.webp';
import img2 from '../../assets/images/blog/tendencias-decoracion-2026.webp';
import img3 from '../../assets/images/blog/diseno-bienestar.webp';

const posts = [
  {
    date: '15 enero 2026',
    title: 'Interiorismo centrado en las personas',
    excerpt: 'Cómo el diseño centrado en el ser humano transforma viviendas y negocios en Madrid. Los 5 pilares del interiorismo que mejora tu vida.',
    href: '/blog/interiorismo-centrado-personas',
    image: img1.src,
    alt: 'Interiorismo centrado en las personas — ByHilde Madrid',
  },
  {
    date: '10 febrero 2026',
    title: 'Tendencias de decoración 2026 que transformarán tu hogar',
    excerpt: 'Minimalismo cálido, texturas orgánicas, formas curvas y sostenibilidad integrada. Las 8 tendencias que están definiendo los hogares en Madrid.',
    href: '/blog/tendencias-decoracion-2026',
    image: img2.src,
    alt: 'Tendencias de decoración de interiores 2026',
  },
  {
    date: '3 marzo 2026',
    title: 'Diseño de interiores y bienestar',
    excerpt: 'Neurointeriorismo, diseño biofílico y estrategias con base científica para crear hogares que cuidan tu salud física y emocional.',
    href: '/blog/diseno-bienestar',
    image: img3.src,
    alt: 'Diseño de interiores y bienestar — hogar saludable',
  },
];
---

<section class="section" style="background: var(--bg);">
  <div class="container">
    <div class="journal-header">
      <div>
        <div class="section-label">Inspiración y tendencias</div>
        <h2 class="editorial-headline">El <em>blog</em> de ByHilde</h2>
      </div>
      <a href="/blog" class="see-all">
        Ver todos los artículos
        <ArrowIcon size={14} />
      </a>
    </div>
    <div class="journal-grid">
      {posts.map((post) => (
        <a href={post.href} class="journal-card">
          <div class="journal-card-img">
            <img src={post.image} alt={post.alt} width="700" height="467" loading="lazy">
          </div>
          <div class="journal-card-body">
            <div class="journal-date">{post.date}</div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <span class="journal-read">
              Leer artículo
              <ArrowIcon size={14} />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .journal-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
  }
  .journal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .journal-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform .3s, box-shadow .3s;
    cursor: pointer;
    display: block;
  }
  .journal-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(26,25,22,.10);
  }
  .journal-card-img {
    height: 200px;
    overflow: hidden;
  }
  .journal-card-img img {
    height: 100%;
    transition: transform .5s;
  }
  .journal-card:hover .journal-card-img img { transform: scale(1.06); }
  .journal-card-body { padding: 22px 24px 26px; }
  .journal-date {
    font-size: 11.5px;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .journal-card h3 {
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 10px;
  }
  .journal-card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .journal-read {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap .2s;
  }
  .journal-card:hover .journal-read { gap: 10px; }

  @media (max-width: 1024px) {
    .journal-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .journal-grid { grid-template-columns: 1fr; }
  }
</style>
