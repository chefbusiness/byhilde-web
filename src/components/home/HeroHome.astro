---
import heroImg from '../../assets/images/home/home-hero-01.webp';
---

<section class="hero">
  <img
    src={heroImg.src}
    alt="Proyecto de interiorismo residencial en Madrid — ByHilde"
    width="1376"
    height="768"
    loading="eager"
  >
  <div class="hero-card">
    <div class="hero-card-label">Interiorismo residencial · Madrid</div>
    <h2>Calidez y luz en la zona noroeste</h2>
    <p>Materiales nobles, líneas limpias y conexión con el entorno. Espacios diseñados para vivir mejor.</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    margin: 20px 20px 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 82vh;
    min-height: 560px;
  }
  .hero img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    transition: transform 8s ease;
  }
  .hero:hover img { transform: scale(1.03); }
  .hero-card {
    position: absolute;
    left: 28px;
    bottom: 28px;
    background: rgba(255,255,255,.88);
    backdrop-filter: blur(20px);
    border-radius: var(--radius-md);
    padding: 24px 28px;
    max-width: 320px;
    border: 1px solid rgba(255,255,255,.6);
  }
  .hero-card-label {
    font-family: var(--body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .10em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .hero-card h2 {
    font-family: var(--sans);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 10px;
  }
  .hero-card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .hero { margin: 12px 12px 0; height: 70vh; min-height: 420px; }
    .hero-card {
      left: 12px;
      right: 12px;
      bottom: 12px;
      max-width: none;
      padding: 18px 20px;
    }
    .hero-card h2 { font-size: 18px; }
    .hero-card p { font-size: 12.5px; }
  }
</style>
