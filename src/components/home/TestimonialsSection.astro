---
const testimonials = [
  {
    text: '"Hilde transformó nuestra casa en algo que ni siquiera habíamos imaginado posible. Cada detalle tiene un porqué, cada rincón tiene alma."',
    name: 'Isabel M.',
    role: 'Propietaria, Ático Retiro · Madrid',
    gradient: 'linear-gradient(135deg,#C0AA90,#9A8570)',
  },
  {
    text: '"Para el interiorismo de Stillroom necesitábamos a alguien que entendiera la experiencia gastronómica desde adentro. Hilde lo entendió perfectamente."',
    name: 'Carlos V.',
    role: 'Fundador, Stillroom · Madrid',
    gradient: 'linear-gradient(135deg,#8B8178,#5A5350)',
  },
  {
    text: '"Gestión impecable de principio a fin. La reforma de nuestra clínica quedó exactamente como lo soñamos — funcional, elegante y completamente nosotros."',
    name: 'Dra. Ana R.',
    role: 'Directora, Clínica Velázquez · Madrid',
    gradient: 'linear-gradient(135deg,#D4C4B0,#B8A99A)',
  },
];

const stars = Array(5).fill('★');
---

<section class="section testimonials-section">
  <div class="container">
    <div class="testimonials-header">
      <div>
        <div class="section-label">Lo que dicen</div>
        <h2 class="editorial-headline">Clientes que <em>confían</em></h2>
      </div>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t) => (
        <div class="testimonial-card">
          <div class="testimonial-stars">
            {stars.map((s) => <span>{s}</span>)}
          </div>
          <p class="testimonial-text">{t.text}</p>
          <div class="testimonial-author">
            <div class="author-avatar" style={`background:${t.gradient};`}></div>
            <div>
              <div class="author-name">{t.name}</div>
              <div class="author-role">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section { background: var(--surface); }
  .testimonials-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .testimonial-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 32px;
  }
  .testimonial-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }
  .testimonial-stars span { color: var(--accent-dark); font-size: 14px; }
  .testimonial-text {
    font-family: var(--serif);
    font-size: 17px;
    font-style: italic;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 20px;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  .author-name {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
  }
  .author-role { font-size: 12px; color: var(--muted); margin-top: 2px; }

  @media (max-width: 1024px) {
    .testimonials-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 768px) {
    .testimonials-grid { grid-template-columns: 1fr; }
  }
</style>
