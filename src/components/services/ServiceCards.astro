---
interface ServiceCard {
  title: string;
  description: string;
}

interface Props {
  title: string;
  cards: ServiceCard[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  cards,
  ctaText = 'Te escucho',
  ctaHref = '/contacto',
} = Astro.props;

const cardIcons = [
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>',
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 3a6 6 0 00-6 6c0 7 6 12 6 12s6-5 6-12a6 6 0 00-6-6z"/></svg>',
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>',
  '<svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>',
];
---

<section class="sub-services section">
  <div class="container">
    <div class="sub-services__header">
      <h2 class="editorial-headline">{title}</h2>
      <a href={ctaHref} class="btn-outline">{ctaText}</a>
    </div>
    <div class="sub-services__grid">
      {cards.map((card, i) => (
        <div class="sub-card">
          <div class="sub-card__icon" set:html={cardIcons[i % cardIcons.length]} />
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sub-services__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .sub-services__header h2 {
    font-size: clamp(26px, 3.5vw, 42px);
  }
  .sub-services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .sub-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    border: 1px solid var(--border);
    transition: transform .3s, box-shadow .3s;
  }
  .sub-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,.06);
  }
  .sub-card__icon {
    color: var(--accent-dark);
    margin-bottom: 16px;
  }
  .sub-card h3 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .sub-card p {
    color: var(--muted);
    font-size: 14.5px;
    line-height: 1.65;
  }
  @media (max-width: 960px) {
    .sub-services__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .sub-services__grid { grid-template-columns: 1fr; }
    .sub-services__header { flex-direction: column; align-items: flex-start; }
  }
</style>
