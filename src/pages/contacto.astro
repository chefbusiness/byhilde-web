---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArrowIcon from '../components/ArrowIcon.astro';
import { siteConfig } from '../config/site.config';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto — ByHilde',
  description: 'Contacta con ByHilde para tu proyecto de interiorismo en Madrid. Consulta gratuita sin compromiso.',
  url: `${siteConfig.url}/contacto`,
  mainEntity: {
    '@type': 'LocalBusiness',
    '@id': `${siteConfig.url}/#business`,
    name: siteConfig.name,
    telephone: siteConfig.phone,
    email: siteConfig.email,
  },
};
---

<BaseLayout
  title="Contacto"
  description="Contacta con ByHilde para tu proyecto de interiorismo en Madrid. Consulta gratuita sin compromiso."
  jsonLd={jsonLd}
>
  <section class="contact-hero section">
    <div class="container">
      <h1 class="editorial-headline">¿Tienes un <em>proyecto</em>?</h1>
      <p class="contact-hero__sub">Convierte tu espacio en algo excepcional. Contáctame hoy y empecemos a crear juntos tu proyecto soñado.</p>
    </div>
  </section>

  <section class="contact-main section-sm">
    <div class="container">
      <div class="contact-grid">
        <!-- Formulario -->
        <form class="contact-form" name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contacto">
          <p class="hidden" style="display:none"><input name="bot-field"></p>

          <div class="form-group">
            <label for="nombre">Nombre completo *</label>
            <input type="text" id="nombre" name="nombre" required autocomplete="name">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required autocomplete="email">
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" autocomplete="tel">
            </div>
          </div>

          <div class="form-group">
            <label for="tipo">Tipo de proyecto</label>
            <select id="tipo" name="tipo">
              <option value="">Selecciona una opción</option>
              <option value="decoracion">Decoración de interiores</option>
              <option value="comercial">Interiorismo comercial</option>
              <option value="reforma">Reforma integral</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje">Cuéntanos tu proyecto *</label>
            <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
          </div>

          <div class="form-group form-check">
            <label>
              <input type="checkbox" name="privacidad" required>
              <span>He leído y acepto la <a href="/aviso-legal" target="_blank">política de privacidad</a></span>
            </label>
          </div>

          <button type="submit" class="btn-primary">
            Enviar solicitud
            <ArrowIcon />
          </button>
          <p class="form-note">Te responderé en menos de 24h</p>
        </form>

        <!-- Datos de contacto -->
        <div class="contact-info">
          <div class="contact-info__block">
            <h2>Contacto directo</h2>
            <ul>
              <li>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}>{siteConfig.phoneDisplay}</a>
              </li>
              <li>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              </li>
              <li>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{siteConfig.address.street}<br>{siteConfig.address.postalCode} {siteConfig.address.city}<br>{siteConfig.address.region}, {siteConfig.address.country}</span>
              </li>
            </ul>
          </div>

          <div class="contact-info__block">
            <h2>Horario</h2>
            <p>{siteConfig.schedule}</p>
          </div>

          <a href={siteConfig.whatsappUrl} class="btn-whatsapp" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp directo
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { text-align: center; padding-bottom: 32px; }
  .contact-hero h1 { margin-bottom: 16px; }
  .contact-hero__sub {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 64px;
    align-items: start;
  }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--body);
    font-size: 15px;
    background: var(--surface);
    color: var(--ink);
    transition: border-color .2s;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .form-group textarea { resize: vertical; }
  .form-check label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
  }
  .form-check input[type="checkbox"] { margin-top: 2px; accent-color: var(--accent-dark); }
  .form-check a { color: var(--ink); text-decoration: underline; }
  .form-note { font-size: 13px; color: var(--muted); margin-top: -8px; }

  /* Contact info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 36px 32px;
    background: var(--surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }
  .contact-info__block h2 {
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .contact-info__block ul { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .contact-info__block li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.6;
  }
  .contact-info__block li svg { flex-shrink: 0; color: var(--accent-dark); margin-top: 2px; }
  .contact-info__block li a { color: var(--muted); transition: color .2s; }
  .contact-info__block li a:hover { color: var(--ink); }
  .contact-info__block p { font-size: 14.5px; color: var(--muted); }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-family: var(--body);
    font-size: 14px;
    font-weight: 500;
    padding: 14px 28px;
    border-radius: 999px;
    transition: opacity .2s;
  }
  .btn-whatsapp:hover { opacity: .9; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 36px; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
