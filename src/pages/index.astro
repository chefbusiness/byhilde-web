---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site.config';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: siteConfig.name,
  description: siteConfig.description,
  url: siteConfig.url,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.city,
    addressRegion: siteConfig.address.region,
    postalCode: siteConfig.address.postalCode,
    addressCountry: 'ES',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Comunidad de Madrid',
  },
  priceRange: '€€€',
};
---

<BaseLayout
  title="Home"
  description={siteConfig.description}
  jsonLd={jsonLd}
>
  <section class="hero">
    <img
      src="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=1600&q=80&auto=format&fit=crop"
      alt="Proyecto de interiorismo residencial en Madrid"
      loading="eager"
    >
    <div class="hero-card">
      <div class="hero-card-label">Proyecto destacado · 2024</div>
      <h2>Stillroom — Gastro Cocktail Bar</h2>
      <p>Diseño de interiores para espacio gastronómico en Madrid. Materiales nobles, atmósfera sofisticada.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    margin: 20px 20px 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 82vh;
    min-height: 560px;
  }
  .hero img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    transition: transform 8s ease;
  }
  .hero:hover img { transform: scale(1.03); }
  .hero-card {
    position: absolute;
    left: 28px;
    bottom: 28px;
    background: rgba(255,255,255,.88);
    backdrop-filter: blur(20px);
    border-radius: var(--radius-md);
    padding: 24px 28px;
    max-width: 320px;
    border: 1px solid rgba(255,255,255,.6);
  }
  .hero-card-label {
    font-family: var(--body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .10em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .hero-card h2 {
    font-family: var(--sans);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 10px;
  }
  .hero-card p {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero { margin: 12px 12px 0; height: 70vh; }
  }
</style>
