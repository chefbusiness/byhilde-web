---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAFinal from '../../components/CTAFinal.astro';
import ArrowIcon from '../../components/ArrowIcon.astro';
import { siteConfig } from '../../config/site.config';

import coverImg from '../../assets/images/proyectos/stillroom/stillroom-cover.webp';

const details = [
  { label: 'Cliente', value: 'Alejandro Márquez' },
  { label: 'Ubicación', value: 'Madrid' },
  { label: 'Año', value: '2026' },
  { label: 'Superficie', value: '160 m²' },
  { label: 'Tipología', value: 'Interiorismo comercial' },
  { label: 'Servicios', value: 'Diseño de interiores + dirección de obra' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Stillroom — Gastro Cocktail Bar | Proyecto ByHilde',
  description: 'Diseño de interiores para Stillroom, gastro cocktail bar en Madrid. Materiales nobles, iluminación escénica y atmósfera sofisticada.',
  url: `${siteConfig.url}/proyectos/stillroom`,
  creator: { '@type': 'Organization', name: siteConfig.name, url: siteConfig.url },
  locationCreated: { '@type': 'Place', name: 'Madrid' },
};
---

<BaseLayout
  title="Stillroom — Diseño de Interiores Gastro Cocktail Bar Madrid | ByHilde"
  description="Diseño de interiores para Stillroom, gastro cocktail bar en Madrid. Materiales nobles, iluminación escénica y atmósfera sofisticada."
  jsonLd={jsonLd}
>
  <section class="project-hero">
    <img src={coverImg.src} alt="Stillroom — gastro cocktail bar diseñado por ByHilde en Madrid" width="1400" height="800" loading="eager" />
    <div class="project-hero__overlay">
      <span class="project-hero__label">Interiorismo comercial · 2026</span>
      <h1>Stillroom</h1>
    </div>
  </section>

  <section class="project-details section">
    <div class="container">
      <div class="project-details__grid">
        <div class="project-details__intro">
          <h2>Donde la coctelería se convierte en experiencia</h2>
          <p>Stillroom nació de la visión de Alejandro Márquez: crear un espacio gastronómico en Madrid donde la coctelería de autor y la gastronomía se fundieran en una experiencia sensorial completa. Necesitaba un interiorismo que entendiera la experiencia gastronómica desde adentro.</p>
          <p>Diseñamos un espacio de 160 m² que combina materiales nobles — madera oscura, latón envejecido, cuero natural — con una iluminación escénica que transforma el local a lo largo de la jornada: luminoso y acogedor en las horas del vermut, íntimo y sofisticado por la noche.</p>
        </div>
        <div class="project-details__meta">
          {details.map((d) => (
            <div class="detail-row">
              <span class="detail-label">{d.label}</span>
              <span class="detail-value">{d.value}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="project-process section">
    <div class="container">
      <div class="project-process__inner">
        <h2>La atmósfera como ingrediente</h2>
        <p>Cada decisión de diseño se tomó pensando en la experiencia del cliente: la <strong>barra de mármol verde Guatemala</strong> como pieza central, los <strong>reservados tapizados en terciopelo</strong> para conversaciones íntimas, y una <strong>bodega acristalada</strong> que funciona como elemento decorativo y práctico.</p>
        <p>La acústica fue un factor clave. Diseñamos un sistema de paneles absorbentes ocultos tras los revestimientos de madera para que el nivel de ruido permitiera conversar cómodamente incluso con el local lleno.</p>
        <blockquote>
          "Para el interiorismo de Stillroom necesitábamos a alguien que entendiera la experiencia gastronómica desde adentro. Hilde lo entendió perfectamente."
          <cite>— Alejandro Márquez, fundador</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <section class="project-nav section-sm">
    <div class="container">
      <div class="project-nav__inner">
        <a href="/proyectos/atico-retiro" class="project-nav__link">
          <span>Siguiente proyecto</span>
          <strong>Ático Retiro <ArrowIcon size={14} /></strong>
        </a>
      </div>
    </div>
  </section>

  <CTAFinal />
</BaseLayout>

<style>
  .project-hero {
    position: relative;
    margin: 20px 20px 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 70vh;
    min-height: 480px;
  }
  .project-hero img { width: 100%; height: 100%; object-fit: cover; }
  .project-hero__overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 48px 40px;
    background: linear-gradient(transparent, rgba(0,0,0,.55));
    color: white;
  }
  .project-hero__label {
    font-size: 11px; font-weight: 500; letter-spacing: .10em;
    text-transform: uppercase; opacity: .85; display: block; margin-bottom: 8px;
  }
  .project-hero h1 { font-family: var(--sans); font-size: clamp(32px, 5vw, 56px); font-weight: 800; }

  .project-details__grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 64px; align-items: start; }
  .project-details__intro h2 { font-family: var(--sans); font-size: 28px; font-weight: 700; margin-bottom: 20px; }
  .project-details__intro p { color: var(--muted); font-size: 16px; line-height: 1.8; margin-bottom: 16px; }
  .project-details__meta { background: var(--surface); border-radius: var(--radius-lg); padding: 32px; border: 1px solid var(--border); }
  .detail-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { color: var(--muted); }
  .detail-value { font-weight: 600; text-align: right; }

  .project-process__inner { max-width: 720px; margin: 0 auto; }
  .project-process__inner h2 { font-family: var(--sans); font-size: 24px; font-weight: 700; margin-bottom: 20px; }
  .project-process__inner p { color: var(--muted); font-size: 16px; line-height: 1.8; margin-bottom: 16px; }
  .project-process__inner strong { color: var(--ink); }

  blockquote {
    margin: 28px 0 0; padding: 24px 28px;
    border-left: 3px solid var(--accent); background: var(--surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-family: var(--serif); font-size: 18px; font-style: italic; line-height: 1.7; color: var(--ink);
  }
  blockquote cite { display: block; font-family: var(--body); font-size: 13px; font-style: normal; color: var(--muted); margin-top: 12px; }

  .project-nav__inner { display: flex; justify-content: flex-end; padding-top: 32px; border-top: 1px solid var(--border); }
  .project-nav__link { text-align: right; }
  .project-nav__link span { font-size: 12px; color: var(--muted); display: block; margin-bottom: 4px; }
  .project-nav__link strong { font-family: var(--sans); font-size: 18px; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; transition: gap .2s; }
  .project-nav__link:hover strong { gap: 14px; }

  @media (max-width: 768px) {
    .project-hero { margin: 12px; height: 50vh; min-height: 320px; }
    .project-hero__overlay { padding: 28px 20px; }
    .project-details__grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
