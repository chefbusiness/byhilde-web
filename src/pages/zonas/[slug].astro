---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArrowIcon from '../../components/ArrowIcon.astro';
import ServiceFAQ from '../../components/services/ServiceFAQ.astro';
import CTAFinal from '../../components/CTAFinal.astro';
import { siteConfig } from '../../config/site.config';
import { zones, getZonesByArea } from '../../data/zones';
import type { Zone } from '../../data/zones';

export function getStaticPaths() {
  return zones.map((zone) => ({
    params: { slug: zone.slug },
    props: { zone },
  }));
}

interface Props { zone: Zone; }
const { zone } = Astro.props;

const services = [
  {
    title: `Decoración de Interiores en ${zone.name}`,
    description: `Transformamos viviendas en ${zone.name} con diseño personalizado, materiales premium y atención al detalle. Pisos, chalets, áticos y dúplex.`,
    href: '/servicios/decoracion-interiores',
    icon: '<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  },
  {
    title: `Interiorismo Comercial en ${zone.name}`,
    description: `Diseño de interiores para restaurantes, oficinas, clínicas, peluquerías y locales comerciales en ${zone.name}. Espacios que venden.`,
    href: '/servicios/interiorismo-comercial',
    icon: '<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>',
  },
  {
    title: `Reformas Integrales en ${zone.name}`,
    description: `Reformas llave en mano en ${zone.name}: cocinas, baños, pisos completos, oficinas y locales. Diseño, coordinación y ejecución sin complicaciones.`,
    href: '/servicios/reformas-integrales',
    icon: '<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>',
  },
];

const residentialTypes = [
  'Pisos y apartamentos',
  'Chalets y viviendas unifamiliares',
  'Áticos y dúplex',
];

const commercialTypes = [
  'Locales comerciales y boutiques',
  'Restaurantes, bares y cafeterías',
  'Oficinas y coworkings',
  'Clínicas y consultas médicas',
  'Centros de estética y peluquerías',
  'Gimnasios y otros negocios',
];

const faqItems = [
  {
    question: `¿Trabajáis en ${zone.name}?`,
    answer: `Sí, realizamos proyectos de interiorismo, decoración y reformas integrales en ${zone.name} y toda la ${zone.areaLabel}. Nuestro estudio está en Villanueva de la Cañada, lo que nos permite atender ${zone.name} con total cercanía.`,
  },
  {
    question: `¿Cuánto cuesta un proyecto de interiorismo en ${zone.name}?`,
    answer: `Cada proyecto es único y el presupuesto depende del tamaño del espacio, el alcance del trabajo y los materiales elegidos. Ofrecemos una consulta inicial gratuita donde evaluamos tus necesidades y te presentamos una propuesta detallada sin compromiso.`,
  },
  {
    question: `¿Hacéis reformas integrales llave en mano en ${zone.name}?`,
    answer: `Sí, ofrecemos un servicio completo de reforma llave en mano: desde el diseño inicial hasta la entrega final, coordinando todos los gremios y proveedores para que tú no tengas que preocuparte de nada.`,
  },
  {
    question: `¿Qué tipos de inmuebles diseñáis en ${zone.name}?`,
    answer: `Trabajamos tanto en residencial (pisos, chalets, áticos, dúplex) como en comercial (restaurantes, oficinas, clínicas, peluquerías, locales comerciales, gimnasios). Adaptamos cada proyecto a las necesidades específicas del espacio y del cliente.`,
  },
];

// Related zones (same area, excluding current)
const relatedZones = getZonesByArea(zone.area).filter((z) => z.slug !== zone.slug).slice(0, 6);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteConfig.url}/zonas/${zone.slug}#business`,
  name: `ByHilde — Interiorismo en ${zone.name}`,
  description: `Estudio de interiorismo, decoración y reformas integrales en ${zone.name}. Diseño personalizado para viviendas y locales comerciales.`,
  url: `${siteConfig.url}/zonas/${zone.slug}`,
  telephone: siteConfig.phone,
  email: siteConfig.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteConfig.address.street,
    addressLocality: siteConfig.address.city,
    addressRegion: siteConfig.address.region,
    postalCode: siteConfig.address.postalCode,
    addressCountry: 'ES',
  },
  areaServed: {
    '@type': zone.type === 'distrito' ? 'City' : 'AdministrativeArea',
    name: zone.name,
    ...(zone.type === 'distrito' && { containedInPlace: { '@type': 'City', name: 'Madrid' } }),
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Servicios de Interiorismo en ${zone.name}`,
    itemListElement: services.map((s) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: s.title },
    })),
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Zonas', item: `${siteConfig.url}/zonas` },
    { '@type': 'ListItem', position: 3, name: zone.name, item: `${siteConfig.url}/zonas/${zone.slug}` },
  ],
};
---

<BaseLayout
  title={`Interiorismo y Reformas en ${zone.name} · Madrid`}
  description={`Estudio de interiorismo, decoración y reformas integrales en ${zone.name}. Diseño personalizado para viviendas y locales comerciales. Consulta gratuita.`}
  jsonLd={[jsonLd, faqJsonLd, breadcrumbJsonLd]}
>
  <!-- Breadcrumb -->
  <nav class="breadcrumb section-sm" aria-label="Migas de pan">
    <div class="container">
      <ol>
        <li><a href="/">Inicio</a></li>
        <li><a href="/zonas">Zonas</a></li>
        <li aria-current="page">{zone.name}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="zone-hero section-sm">
    <div class="container">
      <span class="section-label">{zone.areaLabel} · {zone.type === 'distrito' ? 'Distrito' : 'Municipio'}</span>
      <h1 class="editorial-headline">Interiorismo y Reformas en <em>{zone.name}</em></h1>
      <p class="zone-hero__desc">{zone.description}</p>
      <div class="zone-hero__cta">
        <a href="/contacto" class="btn-primary">
          Consulta gratuita
          <ArrowIcon />
        </a>
        <a href={siteConfig.whatsappUrl} class="btn-outline" target="_blank" rel="noopener">WhatsApp directo</a>
      </div>
      {zone.neighborhoods && (
        <div class="zone-hero__barrios">
          <span class="zone-hero__barrios-label">Barrios:</span>
          {zone.neighborhoods.map((b) => (
            <span class="zone-tag">{b}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Services in this zone -->
  <section class="zone-services section">
    <div class="container">
      <h2 class="editorial-headline zone-services__title">Nuestros servicios en <em>{zone.name}</em></h2>
      <div class="zone-services__grid">
        {services.map((s) => (
          <a href={s.href} class="zone-service-card">
            <div class="zone-service-card__icon" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <span class="see-all">
              Ver servicio
              <ArrowIcon />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Property types -->
  <section class="zone-types section">
    <div class="container">
      <h2 class="editorial-headline zone-types__title">¿Qué tipo de espacio necesitas diseñar en <em>{zone.name}</em>?</h2>
      <div class="zone-types__grid">
        <div class="zone-types__col">
          <h3>Residencial</h3>
          <ul>
            {residentialTypes.map((t) => <li>{t}</li>)}
          </ul>
        </div>
        <div class="zone-types__col">
          <h3>Comercial</h3>
          <ul>
            {commercialTypes.map((t) => <li>{t}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <ServiceFAQ items={faqItems} />

  <!-- Related zones -->
  {relatedZones.length > 0 && (
    <section class="related-zones section-sm">
      <div class="container">
        <h2 class="editorial-headline related-zones__title">También trabajamos en</h2>
        <div class="related-zones__grid">
          {relatedZones.map((z) => (
            <a href={`/zonas/${z.slug}`} class="related-zone-card">
              <span class="related-zone-card__name">{z.name}</span>
              <span class="related-zone-card__type">{z.areaLabel}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTAFinal />
</BaseLayout>

<style>
  /* Breadcrumb */
  .breadcrumb { padding-bottom: 0; }
  .breadcrumb ol {
    display: flex;
    gap: 8px;
    list-style: none;
    font-size: 13px;
    color: var(--muted);
  }
  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: 8px;
    color: var(--border);
  }
  .breadcrumb a { transition: color .2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .breadcrumb [aria-current] { color: var(--ink); font-weight: 500; }

  /* Hero */
  .zone-hero { padding-top: 32px; }
  .zone-hero h1 { margin-bottom: 20px; max-width: 720px; }
  .zone-hero__desc {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: 32px;
  }
  .zone-hero__cta { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 32px; }
  .zone-hero__barrios {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .zone-hero__barrios-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
  }
  .zone-tag {
    display: inline-block;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-size: 13px;
    color: var(--muted);
    background: var(--surface);
  }

  /* Services */
  .zone-services__title { text-align: center; margin-bottom: 48px; }
  .zone-services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .zone-service-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    border: 1px solid var(--border);
    transition: transform .3s, box-shadow .3s;
    display: flex;
    flex-direction: column;
  }
  .zone-service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,.06);
  }
  .zone-service-card__icon {
    color: var(--accent-dark);
    margin-bottom: 20px;
  }
  .zone-service-card h3 {
    font-family: var(--sans);
    font-size: 19px;
    font-weight: 600;
    margin-bottom: 12px;
    line-height: 1.3;
  }
  .zone-service-card p {
    color: var(--muted);
    font-size: 14.5px;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }

  /* Property types */
  .zone-types__title {
    text-align: center;
    margin-bottom: 48px;
    font-size: clamp(26px, 3.5vw, 42px);
  }
  .zone-types__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 800px;
    margin: 0 auto;
  }
  .zone-types__col {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 36px 32px;
    border: 1px solid var(--border);
  }
  .zone-types__col h3 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .zone-types__col ul { list-style: none; }
  .zone-types__col li {
    position: relative;
    padding: 10px 0 10px 24px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.5;
  }
  .zone-types__col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 17px;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  /* Related zones */
  .related-zones__title {
    text-align: center;
    margin-bottom: 36px;
    font-size: clamp(26px, 3.5vw, 42px);
  }
  .related-zones__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 800px;
    margin: 0 auto;
  }
  .related-zone-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 20px 24px;
    background: var(--surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    transition: transform .2s, border-color .2s;
  }
  .related-zone-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  .related-zone-card__name {
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 600;
  }
  .related-zone-card__type {
    font-size: 12px;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .zone-services__grid { grid-template-columns: 1fr; }
    .zone-types__grid { grid-template-columns: 1fr; gap: 24px; }
    .related-zones__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .related-zones__grid { grid-template-columns: 1fr; }
  }
</style>
